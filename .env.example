# ============================================================
# The Sphere — environment variables
# Copy to .env.local for development, or set in Vercel for prod.
# ============================================================

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase "anon" / publishable key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Never expose to the browser.
# Used by API routes via createAdminClient() after an auth guard passes.
SUPABASE_SERVICE_ROLE_KEY=

# NFC wristband signing secret — SERVER ONLY. Must be >= 32 random characters.
# Generate one with:  openssl rand -base64 48
# Changing this invalidates every previously issued wristband token.
NFC_SIGNING_SECRET=

# Public base URL of the deployed app (used for share links / QR profile URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Payments (optional) ──────────────────────────────────────
# Default gateway. "manual" records cash/POS payments and needs no keys.
PAYMENTS_DEFAULT_PROVIDER=manual

# Flash payment gateway — fill once the merchant API docs + credentials exist.
FLASH_API_KEY=
FLASH_MERCHANT_ID=
FLASH_WEBHOOK_SECRET=
FLASH_API_BASE=

# ── Parent login OTP (SMS) ───────────────────────────────────
# "console" = no real SMS. The parent portal falls back to matching a
# registered phone number directly so families can still enter before SMS
# is connected. Set to "gateway" and fill SMS_* once a real provider exists.
SMS_PROVIDER=console
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=TheSphere
# Optional dedicated OTP pepper; falls back to NFC_SIGNING_SECRET if unset.
OTP_SECRET=
